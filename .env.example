# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_username_here
DB_PASSWORD=your_secure_password_here
DB_NAME=talkotopia_db

# ==========================================
# Redis Configuration
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================================
# Application Configuration
# ==========================================
PORT=3000

# ==========================================
# JWT Configuration (Phase 1.2)
# ==========================================
JWT_ACCESS_SECRET=your_secure_jwt_access_secret_here_minimum_32_characters
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_here_minimum_32_characters

# ==========================================
# Environment
# ==========================================
NODE_ENV=development
